@model Group5Flight.Models.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}

<div class="row">

    <!-- LEFT: FILTER PANEL -->
    <div class="col-md-4">
        <form asp-action="Filter" method="post">

            <!-- FROM -->
            <label>From</label>
            <select asp-for="From" class="form-control">
                <option value="">All</option>
                @foreach (var city in Model.FromCities)
                {
                    <option value="@city" selected="@(Model.From == city)">
                        @city
                    </option>
                }
            </select>

            <!-- TO -->
            <label>To</label>
            <select asp-for="To" class="form-control">
                <option value="">All</option>
                @foreach (var city in Model.ToCities)
                {
                    <option value="@city" selected="@(Model.To == city)">
                        @city
                    </option>
                }
            </select>

            <!-- DATE -->
            <label>Departure Date</label>
            <input asp-for="DepartureDate" type="date" class="form-control" />

            <!-- CABIN -->
            <label>Cabin Type</label>
            <select asp-for="CabinType" class="form-control">
                @foreach (var c in Model.CabinTypes)
                {
                    <option value="@c" selected="@(Model.CabinType == c)">
                        @c
                    </option>
                }
            </select>

            <br />
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>

    <!-- RIGHT: RESULTS PANEL -->
    <div class="col-md-8">

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">
                @TempData["Message"]
            </div>
        }

        @foreach (var flight in Model.Flights)
        {
            <div class="card mb-3 p-3">

                <div class="row">

                    <!-- Airline Image -->
                    <div class="col-md-2">
                        <img src="~/images/@flight.Airline.ImageName" width="60" />
                    </div>

                    <!-- Flight Info -->
                    <div class="col-md-6">
                        <strong>@flight.Airline.Name</strong><br />
                        @flight.DepartureTime - @flight.ArrivalTime<br />
                        Duration: @flight.DepartureTime - @flight.ArrivalTime
                    </div>

                    <!-- Extra Info -->
                    <div class="col-md-4">
                        Emission: @flight.Emission<br />
                        Price: $@flight.Price
                    </div>

                </div>

                <!-- 🔥 YOUR FEATURE -->
                <a asp-action="Details" asp-route-id="@flight.FlightId" class="btn btn-sm btn-primary mt-2">
                    View Details
                </a>

            </div>
        }

    </div>
</div>