@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-dark text-white min-vh-100">

    <!-- Airline Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
        <div class="container-fluid">

            <!-- Airline Brand -->
            <a class="navbar-brand"
               asp-area="Airline"
               asp-controller="Home"
               asp-action="Index">
                Airline Panel
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#airlineNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navigation Links -->
            <div class="collapse navbar-collapse" id="airlineNavbar">
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           asp-area="Airline"
                           asp-controller="Home"
                           asp-action="Index">
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Regulation" ? "active" : "")"
                           asp-area="Airline"
                           asp-controller="Home"
                           asp-action="Regulation">
                            Regulation
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Manage" ? "active" : "")"
                           asp-area="Airline"
                           asp-controller="Flights"
                           asp-action="Manage">
                            Manage Flights
                        </a>
                    </li>

                </ul>

                <!-- View Site Button -->
                <a class="btn btn-outline-light"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    View Site
                </a>

            </div>
        </div>
    </nav>

    <!-- Airline Page Content -->
    <div class="container mt-4">
        @RenderBody()
    </div>

</div>