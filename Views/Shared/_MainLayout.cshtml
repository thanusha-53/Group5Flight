@{
Layout = "~/Views/Shared/_Layout.cshtml";
}

<nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom mb-3">
    <div class="container-fluid">

```
    <!-- Brand -->
    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
        Group5Flights
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNavbar">

        <!-- LEFT SIDE -->
        <ul class="navbar-nav me-auto">

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Index" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    Dashboard
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Flights" ? "active" : "")"
                   asp-controller="Flights" asp-action="Search">
                    Search
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Privacy" ? "active" : "")"
                   asp-controller="Home" asp-action="Privacy">
                    Privacy
                </a>
            </li>

        </ul>

        <!-- RIGHT SIDE -->
        <ul class="navbar-nav">

            <li class="nav-item">
                <a class="nav-link"
                   asp-area="Admin" asp-controller="Users" asp-action="Index">
                    Admin
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link"
                   asp-area="Airline" asp-controller="Flights" asp-action="Index">
                    Airline
                </a>
            </li>

        </ul>

    </div>
</div>
