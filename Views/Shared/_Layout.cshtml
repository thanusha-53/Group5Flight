@using Microsoft.AspNetCore.Http

@{
    var selected = Context.Session.GetString("SelectedFlights");
    var count = string.IsNullOrEmpty(selected) ? 0 : selected.Split(',').Length;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Group5Flights</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Group5Flights.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- HEADER (COMMON) -->
    <header class="border-bottom mb-3">
        <div class="container d-flex justify-content-between align-items-center">
            
            <!-- LEFT: Title -->
            <h2>Group5Flights</h2>

            <!-- RIGHT: Badge -->
            <div>
                <span style="font-weight:bold;">
                    Selected Flights
                </span>
                <span style="color:white; background:red; padding:5px 10px; border-radius:15px;">
                    @count
                </span>
            </div>

        </div>
    </header>

    <!-- BODY -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER (COMMON) -->
    <footer class="border-top footer text-muted mt-3">
        <div class="container">
            &copy; 2026 - Group5Flights -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>